{
  "expo": {
    "name": "Bed Space Finder",
    "slug": "bed-space-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android", "web"],
    "splash": {
      "backgroundColor": "#1E3A5F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.bedspacefinder"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E3A5F"
      },
      "package": "com.yourname.bedspacefinder"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}
